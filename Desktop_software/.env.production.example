# ============================================================================
# ANSH AIR COOL - DESKTOP SOFTWARE ENVIRONMENT CONFIGURATION
# Production-Ready Environment Variables
# ============================================================================
# SECURITY: 
# - NEVER commit .env file to version control
# - This file uses the SAME database as backend (Single Database Architecture)
# - Use strong, unique passwords
# ============================================================================

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION (MySQL)
# ----------------------------------------------------------------------------
# CRITICAL: Must match backend database configuration
# Single Database: ac_service_billing

DB_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD
DB_USER=root
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ac_service_billing

# ----------------------------------------------------------------------------
# APPLICATION SETTINGS
# ----------------------------------------------------------------------------
APP_NAME=Ansh Air Cool - Billing System
APP_VERSION=2.0.0
COMPANY_NAME=Ansh Air Cool

# ----------------------------------------------------------------------------
# INVOICE SETTINGS
# ----------------------------------------------------------------------------
INVOICE_PREFIX=INV
INVOICE_START_NUMBER=1001
GST_PERCENTAGE=18.0

# ----------------------------------------------------------------------------
# PDF EXPORT SETTINGS
# ----------------------------------------------------------------------------
PDF_EXPORT_DIR=pdfs
EXPORT_DIR=exports
AUTO_BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24

# ----------------------------------------------------------------------------
# UI SETTINGS
# ----------------------------------------------------------------------------
# Theme: dark, light
DEFAULT_THEME=dark

# Window Settings
WINDOW_WIDTH=1400
WINDOW_HEIGHT=900

# ----------------------------------------------------------------------------
# LOGGING CONFIGURATION
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/desktop_app.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# ----------------------------------------------------------------------------
# AUTO-BACKUP SETTINGS
# ----------------------------------------------------------------------------
AUTO_BACKUP_ENABLED=true
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=30
BACKUP_TIME=02:00  # 24-hour format (2 AM)

# ----------------------------------------------------------------------------
# PRINTER SETTINGS (Optional)
# ----------------------------------------------------------------------------
# DEFAULT_PRINTER_NAME=Your_Printer_Name
# PRINT_INVOICE_AUTOMATICALLY=false

# ----------------------------------------------------------------------------
# UPDATE SETTINGS
# ----------------------------------------------------------------------------
# CHECK_FOR_UPDATES=true
# UPDATE_SERVER_URL=https://your-server.com/updates
