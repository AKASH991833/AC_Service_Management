# Flask Configuration
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES

FLASK_ENV=development
FLASK_DEBUG=True
PORT=5000

# Secret Key for Sessions - GENERATE A RANDOM STRING FOR PRODUCTION
SECRET_KEY=change_this_to_a_random_secure_key_in_production

# API Key for Frontend Authentication - CHANGE THIS IN PRODUCTION
API_KEY=change_this_to_a_secure_api_key_in_production

# Database Configuration (MySQL)
# Format: mysql+pymysql://username:password@host:port/database_name
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/ansh_aircool

# Frontend URL for CORS - Add your production domain here
FRONTEND_URL=http://localhost:5500

# Security Settings
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=3600

# Rate Limiting
RATELIMIT_ENABLED=true
RATELIMIT_DEFAULT=100 per day

# WhatsApp API (Optional)
# WHATSAPP_API_KEY=your_whatsapp_api_key
# WHATSAPP_PHONE=919819104977

# Logging
LOG_LEVEL=DEBUG
LOG_FILE=logs/app.log

# Backup Settings
BACKUP_ENABLED=false
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=7
