# ============================================================================
# ANSH AIR COOL - BACKEND ENVIRONMENT CONFIGURATION
# Production-Ready Environment Variables
# ============================================================================
# SECURITY: 
# - NEVER commit this file to version control
# - Copy this file to .env and fill in your values
# - Use strong, unique passwords and secrets
# - Rotate secrets regularly in production
# ============================================================================

# ----------------------------------------------------------------------------
# FLASK APPLICATION SETTINGS
# ----------------------------------------------------------------------------
FLASK_ENV=production
FLASK_DEBUG=False
PORT=5000

# CRITICAL: Generate secure secret key for production
# Command: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_TO_SECURE_RANDOM_KEY_32_CHARS_MIN

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION (MySQL)
# ----------------------------------------------------------------------------
# Format: mysql+pymysql://username:password@host:port/database_name
# CRITICAL: Use strong database password
DB_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD
DB_USER=root
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ac_service_billing

# SQLAlchemy Database URL (auto-constructed from above)
# Uncomment and use this instead of individual DB_* variables:
# DATABASE_URL=mysql+pymysql://root:your_secure_password@localhost:3306/ac_service_billing

# ----------------------------------------------------------------------------
# SECURITY SETTINGS
# ----------------------------------------------------------------------------
# Session Security
SESSION_COOKIE_SECURE=True  # True in production (HTTPS only)
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=3600  # 1 hour

# Rate Limiting
RATELIMIT_ENABLED=true
RATELIMIT_DEFAULT=100 per day
RATELIMIT_STORAGE_URL=memory://

# ----------------------------------------------------------------------------
# CORS CONFIGURATION
# ----------------------------------------------------------------------------
# Production: Set to your actual domain
FRONTEND_URL=https://yourdomain.com

# For development (localhost):
# FRONTEND_URL=http://localhost:5500

# ----------------------------------------------------------------------------
# LOGGING CONFIGURATION
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/app.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# ----------------------------------------------------------------------------
# FILE UPLOAD SETTINGS
# ----------------------------------------------------------------------------
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=5242880  # 5MB max file size
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,webp

# ----------------------------------------------------------------------------
# WHATSAPP INTEGRATION (Optional)
# ----------------------------------------------------------------------------
# WHATSAPP_API_KEY=your_whatsapp_api_key_here
# WHATSAPP_PHONE=919819104977

# ----------------------------------------------------------------------------
# EMAIL CONFIGURATION (Optional)
# ----------------------------------------------------------------------------
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_USE_TLS=True

# ----------------------------------------------------------------------------
# BACKUP SETTINGS
# ----------------------------------------------------------------------------
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=7
BACKUP_DIR=backups

# ----------------------------------------------------------------------------
# PERFORMANCE SETTINGS
# ----------------------------------------------------------------------------
# Database Connection Pool
SQLALCHEMY_POOL_SIZE=10
SQLALCHEMY_POOL_RECYCLE=3600
SQLALCHEMY_POOL_PRE_PING=true

# Cache (if using Redis)
# REDIS_URL=redis://localhost:6379/0

# ----------------------------------------------------------------------------
# MONITORING & ANALYTICS (Optional)
# ----------------------------------------------------------------------------
# SENTRY_DSN=https://your_sentry_dsn@sentry.io/your_project_id
# ENABLE_ANALYTICS=false
